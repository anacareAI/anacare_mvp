# AnaCare Intelligence Engine — Environment Variables
# Copy this file to .env and fill in real values

# Anthropic Claude API (for CPT mapping)
ANTHROPIC_API_KEY=

# AWS credentials (for S3, Aurora, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 bucket for raw MRF files
S3_BUCKET_RAW=anacare-mrf-raw

# Database (Aurora PostgreSQL)
DB_HOST=
DB_PORT=5432
DB_NAME=anacare
DB_USER=
DB_PASSWORD=

# Target configuration
TARGET_PAYER=aetna
TARGET_METRO=chicago
TARGET_ZIP_PREFIX=606

# Aetna MRF index URL (CMS Transparency in Coverage)
AETNA_MRF_INDEX_URL=https://health1.aetna.com/app/public/#/one/insurerCode=AETNA_GROUP&brandCode=ALFL/machine-readable-transparency-in-coverage?reportingEntityType=Third%20Party%20Administrator_13&lock=true
